# --- Git ---
.git
.gitignore

# --- Python Virtual Environments ---
# These are huge and compiled for your local OS, not Docker's Linux
venv/
env/
.venv/
ENV/

# --- Python Build & Cache ---
__pycache__/
*.py[cod]
*$py.class
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/

# --- Environment Secrets ---
# Crucial: Prevent local secrets from being baked into the image
.env
.env.*
!.env.example
secrets.py

# --- Testing & Documentation ---
# These aren't needed to run the API in production
tests/
docs/
README.md
.github/

# --- OS Specific ---
.DS_Store
Thumbs.db